package-as: flipqueue

enable-nolib-creation: no

# Use the project's CHANGELOG.md as the per-release changelog on
# CurseForge / Wago. Without this the packager auto-generates from git
# commit messages, which are commit-readerese (file paths, fix(FQ-NNN):,
# etc.) — fine for engineers, useless to players reading the project
# page. Pointing at CHANGELOG.md means the project-page release notes
# match what we ship in the addon itself.
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

# Most libraries are vendored directly in Libs/ — the previous wowace SVN
# externals broke builds when repos.wowace.com returned 502/503, so we
# stopped relying on that host. Cogworks-1.0 is fetched from our own
# GitHub repo via a pinned-tag git external (pins to a tag, not to main,
# so upgrades are explicit). The `path` directive copies the contents of
# the Cogworks-1.0 subdirectory of the source repo into Libs/Cogworks-1.0,
# avoiding the double-nested layout a naive repo-level external would
# produce.
externals:
  Libs/Cogworks-1.0:
    url: https://github.com/gezmodean-wow/cogworks.git
    tag: v0.10.0
    path: Cogworks-1.0

# CurseForge / Wago dependency relations. Mirrors the toc's
# `## Dependencies` and `## OptionalDeps`. Without these, the CurseForge
# App and Wago client don't know to auto-install Syndicator alongside
# FlipQueue — which leaves players in the "addon installed but won't
# load (Missing Dependencies)" state.
required-dependencies:
  - syndicator
optional-dependencies:
  - auctionator
  - tradeskill-master

wowi-archive-previous: no

ignore:
  - "*.md"
  - .gitignore
  - .claude
  - .vscode
  - .git
  - .github
  - TODO.md
