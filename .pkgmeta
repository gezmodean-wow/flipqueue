package-as: flipqueue

enable-nolib-creation: no

# Libraries are vendored directly in Libs/ — no externals fetched at build time.
# (The previous wowace SVN externals broke builds when repos.wowace.com returned
# 502/503; vendoring removes the external dependency on a flaky SVN host.)

wowi-archive-previous: no

ignore:
  - "*.md"
  - .gitignore
  - .claude
  - .vscode
  - .git
  - .github
  - TODO.md
